{
  "name": "pokemon-bingo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:pages": "ng build --configuration production --base-href /pokemon-bingo/ --deploy-url /pokemon-bingo/",
    "app:deploy": "npm run build:pages; Copy-Item dist/pokemon-bingo/browser/index.html dist/pokemon-bingo/browser/404.html; npx angular-cli-ghpages --dir=dist/pokemon-bingo/browser",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "angular-cli-ghpages": "^2.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "https-proxy-agent": "^9.0.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
